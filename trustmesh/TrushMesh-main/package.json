{
  "name": "trustmesh-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json && vite build",
    "build:server": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "queues": "tsx src/queues/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@bonfida/spl-name-service": "^3.0.21",
    "@coral-xyz/anchor": "^0.30.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/websocket": "^11.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@noble/ed25519": "^3.1.0",
    "@prisma/client": "^5.22.0",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-phantom": "^0.9.29",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/wallet-adapter-wallets": "^0.19.38",
    "@solana/web3.js": "^1.95.8",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.16.0",
    "bs58": "^6.0.0",
    "bullmq": "^5.23.0",
    "canvas-confetti": "^1.9.4",
    "d3": "^7.9.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.8.1",
    "tweetnacl": "^1.0.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
