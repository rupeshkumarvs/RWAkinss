{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx",
    "src/components/**/*",
    "src/pages/**/*",
    "src/stores/**/*",
    "src/types/**/*",
    "src/lib/axios.ts",
    "src/lib/runtimeConfig.ts",
    "src/lib/utils.ts",
    "src/lib/websocket.ts",
    "src/idl/**/*.ts",
    "src/vite-env.d.ts"
  ]
}
