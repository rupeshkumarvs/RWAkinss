# Database (Supabase PostgreSQL via pgbouncer — add &connection_limit=1 for Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# OpenAI
OPENAI_API_KEY="sk-..."

# Google Gemini
GEMINI_API_KEY="AIza..."

# Supabase (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase service role (server-only — keep secret)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# Solana
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"
NEXT_PUBLIC_PUSD_MINT="YOUR_MINT_ADDRESS"

# PUSD mint authority private key (JSON array — server-only)
PUSD_AUTHORITY_KEY="[1,2,3,...]"
